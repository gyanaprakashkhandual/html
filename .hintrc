{
  "extends": [
    "development"
  ],
  "hints": {
    "axe/forms": "off",
    "no-inline-styles": "off",
    "manifest-file-extension": "off",
    "compat-api/html": [
      "default",
      {
        "ignore": [
          "meta[name=theme-color]"
        ]
      }
    ]
  },
  "browserslist": [
    "defaults",
    "not ie 11",
    "not firefox <= 137",
    "not safari <= 18.3",
    "not ios_saf <= 18.3"
  ]
}